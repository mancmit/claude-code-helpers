# Policy server port (default: 3456)
POLICY_PORT=3456

# Bind address (default: 127.0.0.1, use 0.0.0.0 for remote access)
# POLICY_HOST=127.0.0.1

# Audit log file path (default: ./audit.jsonl)
# AUDIT_LOG=/path/to/audit.jsonl

# ── Authentication ───────────────────────────────────────────────

# Explicit toggle (true/false). When not set, auto-detects from API_KEYS/ADMIN_USERS.
# Set to false to force-disable auth even if keys/users are configured.
# AUTH_ENABLED=true

# API Key auth for hook endpoints (/hooks/*)
# Format: name1:secret1,name2:secret2
# API_KEYS=dev-laptop:mysecret123,ci-server:othersecret456

# Admin auth for UI and API (/api/*)
# Format: user1:password1,user2:password2
# ADMIN_USERS=admin:strongpassword

# JWT secret for admin session tokens (stable across server restarts)
# If not set, a random secret is generated on each start (tokens won't survive restart)
# JWT_SECRET=your-random-secret-here

# ── Client-side (set on the machine running Claude Code) ─────────

# API key to send with hook requests (matches a secret in API_KEYS)
# CLAUDE_CODE_ENFORCE_POLICY_SERVER_API_KEY=mysecret123
